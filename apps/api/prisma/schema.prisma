// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StatutCompteClient {
  ACTIF
  SUSPENDU
}

enum StatutEtablissement {
  ACTIF
  INACTIF
}

enum RoleUtilisateur {
  SUPER_ADMIN
  GERANT
  SERVEUR
}

enum StatutUtilisateur {
  ACTIF
  DESACTIVE
}

enum StatutCategorie {
  ACTIF
  INACTIF
}

enum StatutProduit {
  ACTIF
  INACTIF
}

model CompteClient {
  id          String             @id @default(cuid())
  nomEnseigne String
  statut      StatutCompteClient @default(ACTIF)
  creeLe      DateTime           @default(now())

  etablissements Etablissement[]
  utilisateurs   Utilisateur[]

  @@map("comptes_clients")
}

model Etablissement {
  id      String              @id @default(cuid())
  nom     String
  adresse String?
  ville   String?
  statut  StatutEtablissement @default(ACTIF)
  creeLe  DateTime            @default(now())

  compteClientId String
  compteClient   CompteClient @relation(fields: [compteClientId], references: [id])

  utilisateurs Utilisateur[]
  categories   Categorie[]
  produits     Produit[]

  @@map("etablissements")
}

model Utilisateur {
  id             String            @id @default(cuid())
  role           RoleUtilisateur
  nom            String
  prenom         String
  email          String?           @unique
  motDePasseHash String?
  codePinHash    String?
  statut         StatutUtilisateur @default(ACTIF)
  creeLe         DateTime          @default(now())
  majLe          DateTime          @updatedAt

  compteClientId String?
  compteClient   CompteClient? @relation(fields: [compteClientId], references: [id])

  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])

  @@map("utilisateurs")
}

model Categorie {
  id     String          @id @default(cuid())
  nom    String
  statut StatutCategorie @default(ACTIF)
  creeLe DateTime        @default(now())

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  produits Produit[]

  @@map("categories")
}

model Produit {
  id          String        @id @default(cuid())
  nom         String
  description String?
  prix        Decimal       @db.Decimal(10, 2)
  statut      StatutProduit @default(ACTIF)
  creeLe      DateTime      @default(now())

  categorieId String
  categorie   Categorie @relation(fields: [categorieId], references: [id])

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  @@map("produits")
}
