// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // L'API est compilée en CommonJS : le client doit l'être aussi
  // (en dev, tsx accepte les deux ; en prod, node est strict).
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum StatutCompteClient {
  ACTIF
  SUSPENDU
}

enum StatutEtablissement {
  ACTIF
  INACTIF
}

enum RoleUtilisateur {
  SUPER_ADMIN
  GERANT
  SERVEUR
}

enum StatutUtilisateur {
  ACTIF
  DESACTIVE
}

// Droits spécifiques activables individuellement (en plus du rôle).
enum DroitUtilisateur {
  ANNULER
  CLOTURER
  REMISER
}

// Geste commercial : remise sur l'addition, ou article offert.
enum TypeRemise {
  REMISE
  OFFERT
}

enum StatutCategorie {
  ACTIF
  INACTIF
}

// Sépare le food cost du beverage cost dans les rapports.
enum TypeCategorie {
  NOURRITURE
  BOISSON
}

enum StatutProduit {
  ACTIF
  INACTIF
}

enum CanalCommande {
  SUR_PLACE
  EMPORTER
}

enum StatutCommande {
  ENVOYEE
  PRETE
  ANNULEE
}

enum FormeTable {
  RONDE
  CARREE
  RECTANGULAIRE
}

enum StatutTable {
  ACTIF
  INACTIF
}

enum StatutAddition {
  OUVERTE
  PAYEE
}

enum ModePaiement {
  ESPECES
  CARTE
  CHEQUE
  AUTRE
}

enum StatutJourneeCaisse {
  OUVERTE
  CLOTUREE
}

model CompteClient {
  id          String             @id @default(cuid())
  nomEnseigne String
  statut      StatutCompteClient @default(ACTIF)
  creeLe      DateTime           @default(now())

  etablissements Etablissement[]
  utilisateurs   Utilisateur[]

  @@map("comptes_clients")
}

model Etablissement {
  id                   String              @id @default(cuid())
  nom                  String
  adresse              String?
  ville                String?
  statut               StatutEtablissement @default(ACTIF)
  moyensPaiementActifs ModePaiement[]      @default([ESPECES, CARTE, CHEQUE, AUTRE])
  creeLe               DateTime            @default(now())

  compteClientId String
  compteClient   CompteClient @relation(fields: [compteClientId], references: [id])

  utilisateurs   Utilisateur[]
  categories     Categorie[]
  produits       Produit[]
  commandes      Commande[]
  tables         Table[]
  additions      Addition[]
  annulations    Annulation[]
  journeesCaisse JourneeCaisse[]
  remises        Remise[]

  @@map("etablissements")
}

model Utilisateur {
  id             String            @id @default(cuid())
  role           RoleUtilisateur
  nom            String
  prenom         String
  email          String?           @unique
  motDePasseHash String?
  codePinHash    String?
  droits         DroitUtilisateur[] @default([])
  statut         StatutUtilisateur @default(ACTIF)
  creeLe         DateTime          @default(now())
  majLe          DateTime          @updatedAt

  compteClientId String?
  compteClient   CompteClient? @relation(fields: [compteClientId], references: [id])

  etablissementId String?
  etablissement   Etablissement? @relation(fields: [etablissementId], references: [id])

  commandes            Commande[]
  annulationsValidees  Annulation[] @relation("AnnulationsValidees")
  annulationsDemandees Annulation[] @relation("AnnulationsDemandees")
  journeesOuvertes     JourneeCaisse[] @relation("JourneesOuvertes")
  journeesCloturees    JourneeCaisse[] @relation("JourneesCloturees")
  cloturesDemandees    JourneeCaisse[] @relation("CloturesDemandees")
  remisesAccordees     Remise[]        @relation("RemisesAccordees")
  remisesDemandees     Remise[]        @relation("RemisesDemandees")

  @@map("utilisateurs")
}

model Categorie {
  id     String          @id @default(cuid())
  nom    String
  type   TypeCategorie   @default(NOURRITURE)
  statut StatutCategorie @default(ACTIF)
  creeLe DateTime        @default(now())

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  produits Produit[]

  @@map("categories")
}

model Produit {
  id                      String        @id @default(cuid())
  nom                     String
  description             String?
  prix                    Decimal       @db.Decimal(10, 2)
  // Taux de TVA en % (prix TTC : la TVA est extraite du prix affiché).
  // Algérie : 19 % taux normal, 9 % taux réduit.
  tauxTva                 Int           @default(19)
  // Coût de production saisi par le gérant (matières premières). Sert au food cost.
  coutRevient             Decimal?      @db.Decimal(10, 2)
  tempsPreparationMinutes Int?
  statut                  StatutProduit @default(ACTIF)
  creeLe                  DateTime      @default(now())

  categorieId String
  categorie   Categorie @relation(fields: [categorieId], references: [id])

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  lignesCommande LigneCommande[]
  groupesOptions GroupeOption[]

  @@map("produits")
}

model GroupeOption {
  id          String   @id @default(cuid())
  nom         String
  obligatoire Boolean  @default(false)
  creeLe      DateTime @default(now())

  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])

  valeurs OptionValeur[]

  @@map("groupes_options")
}

model OptionValeur {
  id     String   @id @default(cuid())
  valeur String
  creeLe DateTime @default(now())

  groupeOptionId String
  groupeOption   GroupeOption @relation(fields: [groupeOptionId], references: [id], onDelete: Cascade)

  lignesOptions LigneCommandeOption[]

  @@map("options_valeurs")
}

model Commande {
  id          String         @id @default(cuid())
  canal       CanalCommande
  noteCuisine String?
  statut      StatutCommande @default(ENVOYEE)
  // Générée par la caisse pour les commandes prises hors ligne : garantit
  // qu'une resynchronisation répétée ne crée jamais de doublon.
  cleIdempotence String?     @unique
  creeLe      DateTime       @default(now())
  preteLe     DateTime?

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  serveurId String
  serveur   Utilisateur @relation(fields: [serveurId], references: [id])

  additionId String
  addition   Addition @relation(fields: [additionId], references: [id])

  lignes      LigneCommande[]
  annulations Annulation[]

  @@map("commandes")
}

model LigneCommande {
  id              String   @id @default(cuid())
  nomProduit      String
  prixUnitaire    Decimal  @db.Decimal(10, 2)
  // Coût de revient du produit figé au moment de la commande (comme prixUnitaire).
  coutRevientUnitaire Decimal? @db.Decimal(10, 2)
  // Taux de TVA figé au moment de la commande (null sur l'historique d'avant la TVA).
  tauxTva         Int?
  quantite        Int
  quantitePayee   Int      @default(0)
  quantiteAnnulee Int      @default(0)
  quantiteOfferte Int      @default(0)
  creeLe          DateTime @default(now())

  commandeId String
  commande   Commande @relation(fields: [commandeId], references: [id])

  produitId String
  produit   Produit @relation(fields: [produitId], references: [id])

  options        LigneCommandeOption[]
  paiementLignes PaiementLigne[]
  annulations    Annulation[]
  remises        Remise[]

  @@map("lignes_commande")
}

model Addition {
  id        String         @id @default(cuid())
  statut    StatutAddition @default(OUVERTE)
  ouverteLe DateTime       @default(now())
  fermeeLe  DateTime?

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id])

  commandes Commande[]
  paiements Paiement[]
  remises   Remise[]

  @@map("additions")
}

// Trace de chaque geste commercial : qui, quand, combien, pourquoi.
model Remise {
  id          String     @id @default(cuid())
  type        TypeRemise
  montant     Decimal    @db.Decimal(10, 2)
  // Renseigné si la remise a été saisie en pourcentage.
  pourcentage Int?
  // Renseigné pour un article offert.
  quantite    Int?
  motif       String
  commentaire String?
  creeLe      DateTime   @default(now())

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  additionId String
  addition   Addition @relation(fields: [additionId], references: [id])

  ligneCommandeId String?
  ligneCommande   LigneCommande? @relation(fields: [ligneCommandeId], references: [id])

  // Celui qui porte la responsabilité (serveur avec le droit, ou gérant validant).
  accordeeParId String
  accordeePar   Utilisateur @relation("RemisesAccordees", fields: [accordeeParId], references: [id])

  // Le serveur qui a demandé, quand la validation vient d'un gérant.
  demandeeParId String?
  demandeePar   Utilisateur? @relation("RemisesDemandees", fields: [demandeeParId], references: [id])

  @@map("remises")
}

model Paiement {
  id            String       @id @default(cuid())
  montant       Decimal      @db.Decimal(10, 2)
  moyenPaiement ModePaiement
  montantRecu   Decimal?     @db.Decimal(10, 2)
  creeLe        DateTime     @default(now())

  additionId String
  addition   Addition @relation(fields: [additionId], references: [id])

  journeeCaisseId String?
  journeeCaisse   JourneeCaisse? @relation(fields: [journeeCaisseId], references: [id])

  lignes PaiementLigne[]

  @@map("paiements")
}

// Journée de caisse : ouverte le matin avec un fond de caisse, clôturée le soir
// avec comptage des espèces. Les paiements s'y rattachent au fil de la journée.
model JourneeCaisse {
  id           String              @id @default(cuid())
  statut       StatutJourneeCaisse @default(OUVERTE)
  fondDeCaisse Decimal             @db.Decimal(10, 2)
  ouverteLe    DateTime            @default(now())
  clotureeLe   DateTime?

  // Figés à la clôture : attendu = fond + espèces encaissées, écart = compté − attendu.
  especesAttendues Decimal? @db.Decimal(10, 2)
  especesComptees  Decimal? @db.Decimal(10, 2)
  ecart            Decimal? @db.Decimal(10, 2)
  commentaire      String?

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  ouverteParId String
  ouvertePar   Utilisateur @relation("JourneesOuvertes", fields: [ouverteParId], references: [id])

  // Celui qui porte la responsabilité de la clôture (serveur avec le droit, ou gérant validant).
  clotureeParId String?
  clotureePar   Utilisateur? @relation("JourneesCloturees", fields: [clotureeParId], references: [id])

  // Le serveur qui a demandé, quand la validation vient d'un gérant.
  clotureDemandeeParId String?
  clotureDemandeePar   Utilisateur? @relation("CloturesDemandees", fields: [clotureDemandeeParId], references: [id])

  paiements Paiement[]

  @@map("journees_caisse")
}

model PaiementLigne {
  id       String  @id @default(cuid())
  quantite Int
  montant  Decimal @db.Decimal(10, 2)

  paiementId String
  paiement   Paiement @relation(fields: [paiementId], references: [id])

  ligneCommandeId String
  ligneCommande   LigneCommande @relation(fields: [ligneCommandeId], references: [id])

  @@map("paiements_lignes")
}

model LigneCommandeOption {
  id        String   @id @default(cuid())
  nomGroupe String
  valeur    String
  creeLe    DateTime @default(now())

  ligneCommandeId String
  ligneCommande   LigneCommande @relation(fields: [ligneCommandeId], references: [id])

  optionValeurId String?
  optionValeur   OptionValeur? @relation(fields: [optionValeurId], references: [id], onDelete: SetNull)

  @@map("lignes_commande_options")
}

// Trace de chaque annulation : qui, quand, quoi, pourquoi.
model Annulation {
  id               String   @id @default(cuid())
  motif            String
  commentaire      String?
  quantite         Int
  montant          Decimal  @db.Decimal(10, 2)
  apresPreparation Boolean  @default(false)
  creeLe           DateTime @default(now())

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  commandeId String
  commande   Commande @relation(fields: [commandeId], references: [id])

  ligneCommandeId String?
  ligneCommande   LigneCommande? @relation(fields: [ligneCommandeId], references: [id])

  // Celui qui porte la responsabilité (serveur avec le droit, ou gérant validant).
  annuleeParId String
  annuleePar   Utilisateur @relation("AnnulationsValidees", fields: [annuleeParId], references: [id])

  // Le serveur qui a demandé, quand la validation vient d'un gérant.
  demandeeParId String?
  demandeePar   Utilisateur? @relation("AnnulationsDemandees", fields: [demandeeParId], references: [id])

  @@map("annulations")
}

model Table {
  id             String      @id @default(cuid())
  numero         String
  forme          FormeTable  @default(CARREE)
  nombreCouverts Int
  largeur        Int         @default(80)
  hauteur        Int         @default(80)
  positionX      Int         @default(20)
  positionY      Int         @default(20)
  statut         StatutTable @default(ACTIF)
  creeLe         DateTime    @default(now())

  etablissementId String
  etablissement   Etablissement @relation(fields: [etablissementId], references: [id])

  additions Addition[]

  @@unique([etablissementId, numero])
  @@map("tables")
}
